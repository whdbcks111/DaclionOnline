generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}


// 사용자 테이블
model User {
  id              Int         @id @default(autoincrement())

  username        String      @unique @db.VarChar(50)
  email           String      @unique @db.VarChar(100)
  passwordHash    String      @db.VarChar(255)
  passwordSalt    String      @db.VarChar(128)

  nickname        String      @unique @db.VarChar(50)
  profileImage    String?     @db.VarChar(255) @map("profile_image")
  permission      Int         @default(0)

  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  player          Player?

  @@map("users")
}

// 플레이어 테이블
model Player {
  userId    Int      @id @map("user_id")
  user      User     @relation(fields: [userId], references: [id])

  level      Int      @default(1)
  exp        Int      @default(0)
  maxWeight  Float    @default(100.0) @map("max_weight")
  stats      Json?
  tags       Json?
  locationId String   @db.VarChar(100) @default("town_square") @map("location_id")

  life                Float    @default(100.0)
  mentality           Float    @default(50.0)
  thirsty             Float    @default(100.0)
  hungry              Float    @default(100.0)
  statPoint           Int      @default(0) @map("stat_point")
  gold                Int      @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items           Item[]
  equipments      Equipment[]
  progressEntries PlayerProgress[]
  skills          PlayerSkill[]
  quests          PlayerQuest[]

  @@map("players")
}

// 플레이어별 통계·플래그·상태값. 기본값은 row를 만들지 않는다.
model PlayerProgress {
  playerId  Int      @map("player_id")
  player    Player   @relation(fields: [playerId], references: [userId], onDelete: Cascade)

  key       String   @db.VarChar(150)
  kind      String   @db.VarChar(20)
  intValue  BigInt?  @map("int_value")
  textValue String?  @db.VarChar(255) @map("text_value")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([playerId, key])
  @@index([key, intValue])
  @@map("player_progress")
}

// 코드 SkillData를 참조하는 플레이어별 스킬 인스턴스
model PlayerSkill {
  playerId          Int       @map("player_id")
  player            Player    @relation(fields: [playerId], references: [userId], onDelete: Cascade)

  skillDataId       String    @db.VarChar(100) @map("skill_data_id")
  level             Int       @default(1)
  cooldownEndsAt    DateTime? @map("cooldown_ends_at")
  metadata          Json?
  tags              Json?
  acquisitionSource String?   @db.VarChar(100) @map("acquisition_source")

  acquiredAt        DateTime  @default(now()) @map("acquired_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@id([playerId, skillDataId])
  @@index([skillDataId])
  @@map("player_skills")
}

// 코드 QuestData를 참조하는 플레이어별 퀘스트 진행 상태
model PlayerQuest {
  playerId          Int       @map("player_id")
  player            Player    @relation(fields: [playerId], references: [userId], onDelete: Cascade)

  questDataId       String    @db.VarChar(100) @map("quest_data_id")
  status            String    @db.VarChar(20)
  currentStageId    String    @db.VarChar(100) @map("current_stage_id")
  objectiveProgress Json?     @map("objective_progress")
  metadata          Json?
  tags              Json?
  completionCount   Int       @default(0) @map("completion_count")

  acceptedAt        DateTime  @default(now()) @map("accepted_at")
  readyAt           DateTime? @map("ready_at")
  completedAt       DateTime? @map("completed_at")
  repeatAvailableAt DateTime? @map("repeat_available_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@id([playerId, questDataId])
  @@index([questDataId, status])
  @@map("player_quests")
}

// 플레이어 인벤토리 아이템 테이블
model Item {
  id          Int       @id @default(autoincrement())

  playerId    Int       @map("player_id")
  player      Player    @relation(fields: [playerId], references: [userId], onDelete: Cascade)

  itemDataId  String    @db.VarChar(100) @map("item_data_id")

  count       Int       @default(1)
  durability  Int?
  metadata    Json?
  tags        Json?

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([playerId])
  @@map("items")
}

// 장비 슬롯 테이블
model Equipment {
  id          Int       @id @default(autoincrement())

  playerId    Int       @map("player_id")
  player      Player    @relation(fields: [playerId], references: [userId], onDelete: Cascade)

  itemDataId  String    @db.VarChar(100) @map("item_data_id")

  slot        String    @db.VarChar(50)
  slotIndex   Int       @default(0) @map("slot_index")
  durability  Int?
  metadata    Json?
  tags        Json?

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([playerId, slot, slotIndex])
  @@index([playerId])
  @@map("equipments")
}
